{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oid-see.io/schemas/oidsee-graph-export.schema.json",
  "title": "OID-See Graph Export",
  "type": "object",
  "required": [
    "format",
    "generatedAt",
    "tenant",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "oidsee-graph"
        },
        "version": {
          "type": "string",
          "pattern": "^1\\.(0|[1-9]\\d*)(\\.[0-9]+)?$"
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "tenant": {
      "type": "object",
      "required": [
        "tenantId"
      ],
      "additionalProperties": false,
      "properties": {
        "tenantId": {
          "type": "string",
          "pattern": "^[0-9a-fA-F-]{36}$"
        },
        "displayName": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "cloud": {
          "type": "string",
          "enum": [
            "Public",
            "GCC",
            "GCCHigh",
            "DoD",
            "China",
            "Germany"
          ]
        }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "build": {
              "type": "string"
            }
          }
        },
        "runId": {
          "type": "string"
        },
        "graphApi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseUrl": {
              "type": "string"
            },
            "apiVersion": {
              "type": "string",
              "enum": [
                "v1.0",
                "beta"
              ]
            }
          }
        },
        "scopesUsed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none",
                "safe",
                "aggressive"
              ]
            },
            "hashedFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removedFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodeCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "edgeCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "nodeId": {
      "type": "string",
      "minLength": 1
    },
    "edgeId": {
      "type": "string",
      "minLength": 1
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "displayName",
        "properties"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "type": {
          "type": "string",
          "enum": [
            "OAuthApp",
            "ServicePrincipal",
            "Application",
            "User",
            "Group",
            "Role",
            "TenantPolicy",
            "Organization",
            "ResourceApi"
          ]
        },
        "displayName": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "$ref": "#/$defs/nodeProperties"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        }
      }
    },
    "nodeProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "azureObjectId": {
          "$ref": "#/$defs/uuid"
        },
        "appId": {
          "$ref": "#/$defs/uuid"
        },
        "servicePrincipalId": {
          "$ref": "#/$defs/uuid"
        },
        "tenantId": {
          "$ref": "#/$defs/uuid"
        },
        "userPrincipalName": {
          "type": "string"
        },
        "groupId": {
          "$ref": "#/$defs/uuid"
        },
        "roleTemplateId": {
          "$ref": "#/$defs/uuid"
        },
        "createdDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "lastModifiedDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "verifiedPublisher": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "true=verified publisher; false=unverified; null=unknown/unavailable"
        },
        "publisherName": {
          "type": [
            "string",
            "null"
          ]
        },
        "appOwnerOrganizationId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F-]{36}$"
        },
        "isMultiTenant": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "requiresAssignment": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "appRoleAssignmentRequired"
        },
        "signInAudience": {
          "type": [
            "string",
            "null"
          ]
        },
        "replyUrls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": [
        "id",
        "type",
        "from",
        "to",
        "properties"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/edgeId"
        },
        "type": {
          "type": "string",
          "enum": [
            "CAN_IMPERSONATE",
            "ASSIGNED_TO",
            "HAS_SCOPE",
            "MEMBER_OF",
            "HAS_ROLE",
            "OWNS",
            "GOVERNS",
            "EFFECTIVE_IMPERSONATION_PATH",
            "PERSISTENCE_PATH",
            "INSTANCE_OF"
          ]
        },
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        },
        "properties": {
          "$ref": "#/$defs/edgeProperties"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "derived": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "isDerived": {
              "type": "boolean"
            },
            "algorithm": {
              "type": "string"
            },
            "inputs": {
              "type": "array",
              "description": "IDs of edges/nodes used to derive this edge",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "edgeProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissionType": {
          "type": "string",
          "enum": [
            "delegated",
            "application",
            "unknown"
          ]
        },
        "hasOfflineAccess": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "resource": {
          "type": [
            "string",
            "null"
          ]
        },
        "blastRadius": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "single",
            "group",
            "role",
            "tenant-wide",
            "unknown",
            null
          ]
        },
        "effectivePrivilege": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown",
            null
          ]
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/riskReason"
          }
        }
      }
    },
    "riskReason": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "required": [
        "source",
        "kind"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "graph",
            "token",
            "ests",
            "manual",
            "other"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "graph_response",
            "graph_delta",
            "jwt_claims",
            "ests_config_blob",
            "consent_page",
            "screenshot",
            "note"
          ]
        },
        "id": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "hash": {
          "type": "string",
          "description": "Content hash if stored elsewhere"
        }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "title",
        "affectedNodeIds"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "affectedNodeIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeId"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
