{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oidsee.dev/schemas/oidsee-graph-export.vNext.cleaned.schema.json",
  "title": "OID-See Graph Export Schema (vNext, cleaned - no login endpoint evidence)",
  "type": "object",
  "required": [
    "format",
    "generatedAt",
    "tenant",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "oidsee-graph"
        },
        "version": {
          "type": "string",
          "pattern": "^1\\.(0|[1-9]\\d*)(\\.[0-9]+)?$"
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "tenant": {
      "type": "object",
      "required": [
        "tenantId"
      ],
      "additionalProperties": false,
      "properties": {
        "tenantId": {
          "type": "string",
          "pattern": "^[0-9a-fA-F-]{36}$"
        },
        "displayName": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "cloud": {
          "type": "string",
          "enum": [
            "Public",
            "GCC",
            "GCCHigh",
            "DoD",
            "China",
            "Germany"
          ]
        }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "build": {
              "type": "string"
            }
          }
        },
        "runId": {
          "type": "string"
        },
        "graphApi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseUrl": {
              "type": "string"
            },
            "apiVersion": {
              "type": "string",
              "enum": [
                "v1.0",
                "beta"
              ]
            }
          }
        },
        "scopesUsed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none",
                "safe",
                "aggressive"
              ]
            },
            "hashedFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removedFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodeCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "edgeCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "nodeId": {
      "type": "string",
      "minLength": 1
    },
    "edgeId": {
      "type": "string",
      "minLength": 1
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "displayName",
        "properties"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "type": {
          "type": "string",
          "enum": [
            "OAuthApp",
            "ServicePrincipal",
            "Application",
            "User",
            "Group",
            "Role",
            "TenantPolicy",
            "Organization",
            "ResourceApi"
          ]
        },
        "displayName": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "$ref": "#/$defs/nodeProperties"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        }
      }
    },
    "nodeProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "azureObjectId": {
          "$ref": "#/$defs/uuid"
        },
        "appId": {
          "$ref": "#/$defs/uuid"
        },
        "servicePrincipalId": {
          "$ref": "#/$defs/uuid"
        },
        "tenantId": {
          "$ref": "#/$defs/uuid"
        },
        "userPrincipalName": {
          "type": "string"
        },
        "groupId": {
          "$ref": "#/$defs/uuid"
        },
        "roleTemplateId": {
          "$ref": "#/$defs/uuid"
        },
        "createdDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "lastModifiedDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "verifiedPublisher": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "true=verified publisher; false=unverified; null=unknown/unavailable"
        },
        "publisherName": {
          "type": [
            "string",
            "null"
          ]
        },
        "appOwnerOrganizationId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F-]{36}$"
        },
        "isMultiTenant": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "requiresAssignment": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "appRoleAssignmentRequired"
        },
        "signInAudience": {
          "type": [
            "string",
            "null"
          ]
        },
        "replyUrls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "replyUrlDomains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "eTLD+1 domains extracted from replyUrls (and other URL fields where applicable)."
        },
        "replyUrlAnalysis": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Analysis of reply URLs including security flags (non-HTTPS, IP literals, localhost, punycode, wildcards) and domain clustering."
        },
        "replyUrlEnrichment": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Optional enrichment data for reply URL domains (DNS, RDAP, IPWHOIS lookups). Null if enrichment not performed or failed."
        },
        "replyUrlProvenance": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Provenance metadata for reply URL data (source, collection timestamp, enrichment status)."
        },
        "publicClientIndicators": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Public client and implicit flow indicators from Application object (is_public_client, is_implicit_flow, is_spa, risk_indicators)."
        },
        "platformSignals": {
          "type": "object",
          "description": "Platform classification signals for well-known Microsoft service principals",
          "additionalProperties": false,
          "required": ["isWellKnownMicrosoftAppId", "wellKnownMicrosoftAppName", "isMostlyZeroMicrosoftStyleAppId", "platformAppIdCategory"],
          "properties": {
            "isWellKnownMicrosoftAppId": {
              "type": "boolean",
              "description": "Whether this appId is a recognized Microsoft platform service"
            },
            "wellKnownMicrosoftAppName": {
              "type": ["string", "null"],
              "description": "Human-readable name of the well-known Microsoft service, if applicable"
            },
            "isMostlyZeroMicrosoftStyleAppId": {
              "type": "boolean",
              "description": "Heuristic: Whether the appId follows Microsoft's mostly-zero pattern (e.g., starts with 00000)"
            },
            "platformAppIdCategory": {
              "type": "string",
              "enum": ["well_known", "mostly_zero_heuristic", "normal"],
              "description": "Classification category for the appId"
            }
          }
        },
        "replyUrlDomainSummary": {
          "type": "object",
          "additionalProperties": true,
          "description": "Computed summary of replyUrl domains (primary domain, counts, anomalies)."
        },
        "urlSignals": {
          "type": "object",
          "additionalProperties": true,
          "description": "URL-based trust signals (placeholders for future web/WHOIS/DNS enrichment)."
        },
        "assignments": {
          "type": "object",
          "additionalProperties": true,
          "description": "Assignment-related counts and effective exposure estimates (users, groups, roles)."
        },
        "secrets": {
          "type": "object",
          "additionalProperties": true,
          "description": "Credential material presence/visibility signals (passwordCredentials/keyCredentials counts if returned by Graph)."
        },
        "oauthPermissions": {
          "type": "object",
          "additionalProperties": true,
          "description": "OAuth permission summary (delegated scopes, application roles, offline_access presence, privileged sets)."
        },
        "graphSource": {
          "type": "object",
          "additionalProperties": true,
          "description": "Graph metadata for this object (tenant, apiVersion, fetch timestamps, @odata etag etc)."
        }
      }
    },
    "edge": {
      "type": "object",
      "required": [
        "id",
        "type",
        "from",
        "to",
        "properties"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/edgeId"
        },
        "type": {
          "type": "string",
          "enum": [
            "ASSIGNED_TO",
            "CAN_IMPERSONATE",
            "EFFECTIVE_IMPERSONATION_PATH",
            "GOVERNS",
            "HAS_APP_ROLE",
            "HAS_OFFLINE_ACCESS",
            "HAS_PRIVILEGED_SCOPES",
            "HAS_ROLE",
            "HAS_SCOPE",
            "HAS_SCOPES",
            "HAS_TOO_MANY_SCOPES",
            "INSTANCE_OF",
            "MEMBER_OF",
            "OWNS",
            "PERSISTENCE_PATH"
          ]
        },
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        },
        "properties": {
          "$ref": "#/$defs/edgeProperties"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "derived": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "isDerived": {
              "type": "boolean"
            },
            "algorithm": {
              "type": "string"
            },
            "inputs": {
              "type": "array",
              "description": "IDs of edges/nodes used to derive this edge",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "edgeProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissionType": {
          "type": "string",
          "enum": [
            "delegated",
            "application",
            "unknown"
          ]
        },
        "hasOfflineAccess": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "resource": {
          "type": [
            "string",
            "null"
          ]
        },
        "blastRadius": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "single",
            "group",
            "role",
            "tenant-wide",
            "unknown",
            null
          ]
        },
        "effectivePrivilege": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown",
            null
          ]
        },
        "scope": {
          "type": "string",
          "description": "Scope value for HAS_SCOPE/HAS_SCOPES edges."
        },
        "appRoleId": {
          "type": "string",
          "format": "uuid",
          "description": "App role ID for HAS_APP_ROLE edges."
        },
        "appRoleValue": {
          "type": "string",
          "description": "App role value for HAS_APP_ROLE edges."
        },
        "appRoleDisplayName": {
          "type": "string",
          "description": "App role display name for HAS_APP_ROLE edges."
        },
        "privileged": {
          "type": "boolean",
          "description": "Whether this scope/app role is considered privileged by the scoring logic."
        },
        "source": {
          "type": "string",
          "description": "Source of relationship (Graph endpoint name or derivation)."
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/riskReason"
          }
        },
        "breakdown": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional per-category or per-rule scoring breakdown."
        }
      }
    },
    "riskReason": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "description": "High-level category for the reason (e.g. permissions, persistence, assignments, urls, publisher, secrets)."
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "description": "Structured evidence supporting this scoring decision (e.g. matched scopes, counts, domains)."
        },
        "ruleId": {
          "type": "string",
          "description": "Stable ID of the scoring rule that produced this reason (maps to scoring_logic.json)."
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "required": [
        "source",
        "kind"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "graph",
            "manual",
            "other"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "graph_response",
            "graph_delta",
            "note"
          ]
        },
        "id": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "hash": {
          "type": "string",
          "description": "Content hash if stored elsewhere"
        }
      },
      "description": "Reference to supporting evidence for a node/edge/score finding.\n\nCleaned: evidence kinds are restricted to sources retrievable via Microsoft Graph or public web queries (no Entra login/ scraping)."
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "title",
        "affectedNodeIds"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "affectedNodeIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeId"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}